# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token
GUILD_ID=your_guild_id
SUMMARY_CHANNEL_ID=your_summary_channel_id

# Channel Allowlist (comma-separated channel IDs)
ALLOWED_CHANNEL_IDS=123456789,987654321

# LLM Provider: "openai" or "anthropic"
LLM_PROVIDER=openai

# OpenAI settings (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic settings (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Bot Behavior
TIMEZONE=America/New_York
MAX_CONTEXT_TOKENS=120000
DEFAULT_SUMMARY_MINUTES=240
QUIET_THRESHOLD=5

# Rate Limiting
SUMMARY_COOLDOWN_SECONDS=7200
COOLDOWN_EXEMPT_USER_IDS=

# Thread Delivery (OUT-04): set to true to post summaries in daily threads
USE_THREADS=false
